DATABASE_URL="file:./dev.db"
JWT_SECRET=change-me-to-a-long-random-string
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Initial password for the seeded admin@silverskills.ai account. Only used the first time that
# account is created — re-seeding never overwrites the password afterwards. Change it from /admin
# after your first login instead of relying on this value long-term.
ADMIN_DEFAULT_PASSWORD=SilverSkills2026!

# Optional: activates the full Claude-powered mentor agent + CV analysis.
# Without it, the app runs in rule-based fallback mode (still uses real job/course data & links).
ANTHROPIC_API_KEY=

# Optional: activates real LATAM job listings from Adzuna (free account at https://developer.adzuna.com/).
# Coverage is strong for Mexico/Brazil; Colombia is NOT on Adzuna's supported country list.
# Without it, jobs still come from Remotive + Arbeitnow (no key required) plus portal search deep links.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional: activates real job listings covering Colombia/LATAM broadly. Request a free key by
# filling the form at https://jooble.org/api/about (manual approval, not instant).
JOOBLE_API_KEY=
