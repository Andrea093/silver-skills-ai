DATABASE_URL="file:./dev.db"
JWT_SECRET=change-me-to-a-long-random-string
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Optional: activates the full Claude-powered mentor agent + CV analysis.
# Without it, the app runs in rule-based fallback mode (still uses real job/course data & links).
ANTHROPIC_API_KEY=

# Optional: activates real LATAM job listings from Adzuna (free account at https://developer.adzuna.com/).
# Without it, jobs still come from Remotive + Arbeitnow (no key required) plus portal search deep links.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
